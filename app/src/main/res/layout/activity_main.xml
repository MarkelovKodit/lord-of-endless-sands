<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0E6"
    tools:context=".ui.MainActivity">

    <!-- ==================== -->
    <!-- Верхняя панель (аватарка + кнопки) -->
    <!-- ==================== -->

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Аватарка -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/avatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/loes_test_avatar"
            android:contentDescription="@string/avatar_desc"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Кнопка "Статистика" (по центру) -->
        <Button
            android:id="@+id/btnStats"
            style="@style/TopBarButton"
            android:text="@string/btn_stats"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Кнопка "Рюкзак" -->
        <Button
            android:id="@+id/btnBackpack"
            style="@style/TopBarButton"
            android:text="@string/btn_backpack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ==================== -->
    <!-- Иллюстрация (4:3) -->
    <!-- ==================== -->

    <ImageView
        android:id="@+id/illustration"
        android:layout_width="359dp"
        android:layout_height="174dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="@string/ill_desc"
        android:scaleType="centerCrop"
        android:src="@drawable/loes_test_pic"
        app:layout_constraintDimensionRatio="4:3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

    <!-- ==================== -->
    <!-- Карточка с текстом главы -->
    <!-- ==================== -->

    <androidx.cardview.widget.CardView
        android:id="@+id/chapterCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FDF8F0"
        app:layout_constraintTop_toBottomOf="@+id/illustration"
        app:layout_constraintBottom_toTopOf="@+id/buttonContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:fillViewport="true">

            <TextView
                android:id="@+id/chapterText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:lineSpacingExtra="4dp"
                android:text="@string/chapter_text_placeholder"
                android:textColor="#3E3A38"
                android:textSize="18sp" />

        </ScrollView>
    </androidx.cardview.widget.CardView>

    <!-- ==================== -->
    <!-- Контейнер кнопок выбора -->
    <!-- ==================== -->

    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/choice1"
            style="@style/GameButton"
            android:text="@string/choice1_text" />

        <Button
            android:id="@+id/choice2"
            style="@style/GameButton"
            android:text="@string/choice2_text" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>